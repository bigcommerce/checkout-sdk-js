{
    "name": "cybersource-integration",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/cybersource-integration/src",
    "projectType": "library",
    "targets": {
        "lint": {
            "executor": "@nrwl/linter:eslint",
            "outputs": ["{options.outputFile}"],
            "options": {
                "lintFilePatterns": ["packages/cybersource-integration/**/*.ts"]
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/packages/cybersource-integration"],
            "options": {
                "jestConfig": "packages/cybersource-integration/jest.config.ts"
            }
        }
    },
    "tags": ["scope:integration"]
}
