{
    "name": "cardinal-integration",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "packages/cardinal-integration/src",
    "projectType": "library",
    "targets": {
        "lint": {
            "executor": "@nx/eslint:lint",
            "outputs": ["{options.outputFile}"],
            "options": {
                "lintFilePatterns": ["packages/cardinal-integration/**/*.ts"]
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/packages/cardinal-integration"],
            "options": {
                "jestConfig": "packages/cardinal-integration/jest.config.ts"
            }
        }
    },
    "tags": ["scope:shared"]
}
