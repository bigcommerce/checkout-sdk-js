# @bigcommerce/eslint-config@2.13.1 declares a stale optional peer
# `typescript@"^4.0.0 || ^5.0.0"` that excludes TypeScript 6.x, even though the
# underlying @typescript-eslint 8.x toolchain it wraps already supports TS 6.
# Ignore optional peer conflicts until eslint-config publishes a TS 6 peer range.
legacy-peer-deps=true
